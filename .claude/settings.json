{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-pr-check.sh",
            "timeout": 300,
            "statusMessage": "Running pre-PR checks..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-format.sh",
            "timeout": 30,
            "statusMessage": "Running Prettier..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-format.sh",
            "timeout": 30,
            "statusMessage": "Running Prettier..."
          }
        ]
      }
    ]
  }
}
